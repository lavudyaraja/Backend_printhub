// Prinsta — Smart Self-Service Printing Platform
// Prisma schema (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------------
// ENUMS
// ------------------------------------------------------------------

enum Role {
  STUDENT
  /// A shop owner who registers and runs their own printers.
  VENDOR
  /// Former name for VENDOR. Kept because a Postgres enum value cannot be
  /// dropped while rows still reference it — scripts/backfill-vendors.ts moves
  /// those rows to VENDOR, after which this can go.
  OPERATOR
  /// Platform staff. Sees every vendor.
  ADMIN
}

enum OrderStatus {
  PENDING_PAYMENT // awaiting payment
  PAID // payment confirmed
  READY // file ready, queued for printer
  PRINTING // actively printing
  COMPLETED // print delivered
  FAILED // print failed
  CANCELLED
}

enum ColorMode {
  BW
  COLOR
}

enum SideMode {
  SINGLE
  DOUBLE
}

enum PrinterStatus {
  ONLINE
  OFFLINE
  BUSY
  ERROR
  OUT_OF_PAPER
  LOW_TONER
}

enum PrintJobStatus {
  QUEUED
  SENT
  PRINTING
  DONE
  ERROR
}

/// Points ledger entry type. Renamed from WalletTxnType; `@@map` keeps the
/// existing database enum so no data migration is required.
/// What went wrong, as reported by the user. Kept coarse on purpose — a student
/// standing at a jammed printer should be able to pick in one tap.
enum ComplaintCategory {
  PRINTER_NOT_WORKING // machine dead, won't wake, errored mid-job
  OUT_OF_TONER // faded, streaked or blank-ish output from a dry cartridge
  PAPER_JAM
  OUT_OF_PAPER
  POOR_PRINT_QUALITY // smudged, skewed, wrong colours
  INCOMPLETE_PRINT // some pages missing / job stopped part-way
  BLANK_PAGES // sheets came out empty
  PAYMENT_OR_POINTS // charged but nothing printed, points not refunded
  OTHER
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  /// The shop passed a refund-bearing issue up to the platform to decide.
  FORWARDED
  RESOLVED
  /// Staff granted the refund; a Refund row exists and points are back.
  REFUNDED
  REJECTED
  /// Withdrawn by the user (e.g. the printer started working again).
  CANCELLED
}

enum PointsTxnType {
  CREDIT // top-up / refund
  DEBIT // spent on a print order

  @@map("WalletTxnType")
}

/// Why an order was refunded. Coarse on purpose — it exists to explain the
/// credit on the user's ledger, not to drive logic.
enum RefundReason {
  PRINT_FAILED // the printer reported the job failed
  PRINTER_STUCK // job started and never finished — jam, freeze, power cut
  PRINTER_OFFLINE // machine went away before the job ran
  PARTIAL_PRINT // some pages came out, some didn't
  CANCELLED_BY_USER
  ADMIN_GOODWILL // staff decision, e.g. after a complaint
  OTHER
}

/// How a refund came about. Automatic refunds fire when an order lands in
/// FAILED; manual ones are issued by staff from the console; VENDOR_APPROVED
/// ones are a shop granting a customer's request without staff involvement.
enum RefundOrigin {
  AUTOMATIC
  MANUAL
  VENDOR_APPROVED
}

/// Where a customer's refund request has got to.
///
/// The shop decides first, because they are the ones who saw the machine and
/// the paper. Staff only get involved when the customer disputes a rejection —
/// that is what ESCALATED means, and it is the only path from a "no" to a
/// second opinion.
enum RefundRequestStatus {
  /// Waiting on the shop.
  PENDING
  /// The shop granted it; a Refund row exists and points are back.
  APPROVED
  /// The shop turned it down. The customer can escalate from here.
  REJECTED
  /// The customer disputed a rejection. Now in the platform's queue.
  ESCALATED
  /// Staff overruled the rejection and refunded.
  ESCALATION_APPROVED
  /// Staff agreed with the shop. This is the end of the line.
  ESCALATION_REJECTED
  /// Withdrawn by the customer, e.g. the reprint worked.
  CANCELLED
}

/// Where a payout is in its life. Nothing here talks to a bank — a payout is
/// recorded by staff after they have made the transfer, so PROCESSING means
/// "someone is doing it", not "the money is in flight".
enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum PaymentMethod {
  /// Paid from the user's Prinsta Points balance. The stored value is still
  /// "WALLET" so existing rows keep validating.
  POINTS      @map("WALLET")
  UPI
  CREDIT_CARD
  DEBIT_CARD
  NET_BANKING
}

/// Which way a rating points. Both sides of a completed order may rate the
/// other, and a single Rating table holds both — the pair is far more useful
/// read together (a one-star review next to the vendor's own account of the
/// same order) than split across two tables that only ever get joined.
enum RatingDirection {
  /// The student rating the shop that printed for them.
  USER_TO_VENDOR
  /// The shop rating the student who placed the order.
  VENDOR_TO_USER
}

/// Quick-pick reasons attached to a rating, so feedback is usable without
/// anyone having to type. Kept in one enum rather than two because Prisma
/// cannot scope an enum per direction; which tags may be used with which
/// direction is enforced in ratings/types.ts, where it can carry a message.
enum RatingTag {
  // ── student → shop ──
  PRINT_QUALITY
  FAST_SERVICE
  CLEAN_SHOP
  HELPFUL_STAFF
  FAIR_PRICING
  SLOW_SERVICE
  RUDE_STAFF
  MACHINE_ISSUES
  OVERCHARGED

  // ── shop → student ──
  POLITE
  ON_TIME_PICKUP
  CLEAR_INSTRUCTIONS
  NO_SHOW
  RUDE_BEHAVIOUR
  MISUSED_MACHINE
  WASTED_PAPER
}

/// Moderation state. A hidden rating still counts as "already rated" for the
/// author — hiding is not an invitation to post it again — but drops out of
/// public lists and out of the averages.
enum RatingStatus {
  VISIBLE
  HIDDEN
}

// ------------------------------------------------------------------
// MODELS
// ------------------------------------------------------------------

model User {
  id                 String   @id @default(cuid())
  phone              String?  @unique
  email              String?  @unique
  googleId           String?  @unique
  name               String
  passwordHash       String?
  rollNumber         String?  @unique
  role               Role     @default(STUDENT)
  /// The live balance, in Prinsta Points (1 point = 10 paise — see lib/points.ts).
  pointsBalance      Int      @default(0)
  /// Legacy paise balance. Superseded by pointsBalance and no longer written to.
  /// Kept because deploys use `prisma db push`, which would drop the column (and
  /// every existing balance with it) if this were renamed rather than added
  /// alongside. Safe to delete once scripts/backfill-points.ts has been run and
  /// the new balances verified in production.
  pointsBalancePaise Int      @default(0) @map("walletBalancePaise")
  emailNotifications Boolean  @default(true) // receive order + login emails
  loginAlertSent     Boolean  @default(false) // the "new login" email is sent once, not every sign-in
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  /// This account's own code to share. Generated on first request rather than
  /// at sign-up, so accounts that predate referrals get one too.
  referralCode       String?   @unique
  /// The account whose code this user entered. Set once and never changed —
  /// letting it move would let the reward be claimed repeatedly.
  referredById       String?
  /// Self-relation, so the operator console can list who invited whom without
  /// a second round of lookups. `SetNull` rather than cascade: deleting an
  /// inviter must not take their invitees' accounts with it.
  referredBy         User?     @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals          User[]    @relation("UserReferrals")
  /// When the referral reward was paid out, for both sides. Its presence is
  /// what stops a second payout; the reward fires on the invited user's first
  /// completed order, and orders complete more than once over a lifetime.
  referralRewardedAt DateTime?

  /// Set when an admin bans the account. Null means active — a nullable
  /// timestamp rather than a boolean so "when" and "whether" are one field and
  /// can't disagree.
  bannedAt   DateTime?
  /// Shown to the user on the sign-in screen, so a ban isn't a silent failure.
  banReason  String?
  /// The admin who applied the ban. Not a relation: it points at another User
  /// row, and a self-relation here would need a back-reference that has no use.
  bannedById String?

  /// Average of the VISIBLE stars shops have given this account, and how many
  /// there are. Denormalized: the vendor console shows a customer's standing
  /// while they are placing an order, and averaging their whole rating history
  /// on that path would put a scan of every past order in front of a checkout.
  /// Recomputed inside the same transaction as every rating write — see
  /// ratings/service.ts.
  ratingAvg   Float @default(0)
  ratingCount Int   @default(0)

  documents       Document[]
  orders          Order[]
  notifications   Notification[]
  pointsTxns      PointsTransaction[]
  complaints      Complaint[]
  refunds         Refund[]
  bankAccount     BankAccount?
  /// Ratings this account wrote — as a student about a shop, or, for a vendor
  /// login, about a customer.
  ratingsWritten  Rating[]            @relation("RatingAuthor")
  /// Ratings shops have written about this account.
  ratingsReceived Rating[]            @relation("RatingSubjectUser")
  refundRequests  RefundRequest[]
  /// Set only for vendor-console accounts.
  vendor          Vendor?

  @@index([phone])
  @@index([email])
  /// Counting a user's invitees is a hot path on the referrals screen.
  @@index([referredById])
}

/// Payout destination for a shop owner. One per account. The full account
/// number is stored so payouts can be made, but API responses only ever expose
/// the last four digits.
model BankAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  accountHolder String
  accountNumber String
  ifsc          String
  bankName      String?
  branch        String?
  upiId         String?
  /// Set once the account has been verified (e.g. by a penny drop).
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// The Prinsta Points ledger. Renamed from WalletTransaction; `@@map` keeps
/// the existing table so no data migration is required.
model PointsTransaction {
  id            String        @id @default(cuid())
  userId        String
  type          PointsTxnType
  /// Points moved by this transaction, and the resulting balance.
  amountPoints  Int           @default(0)
  balancePoints Int           @default(0)
  /// Legacy paise figures — see the note on User.pointsBalancePaise.
  amountPaise   Int           @default(0)
  balancePaise  Int           @default(0)
  description   String
  orderId       String?
  razorpayId    String? // Razorpay payment ID
  createdAt     DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("WalletTransaction")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  read      Boolean  @default(false)
  orderId   String?
  /// Where tapping this notification should take the recipient — a console path
  /// (e.g. "/vendor/issues") for shop alerts. Null means it's informational and
  /// isn't linked anywhere.
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model Document {
  id        String    @id @default(cuid())
  userId    String
  fileName  String
  fileType  String // pdf | docx | pptx | image
  fileKey   String // logical key (kept for compatibility)
  mimeType  String? // original upload content-type
  fileData  Bytes? // the file itself, stored in Neon (no external object storage)
  sizeBytes Int
  pageCount Int       @default(1)
  deleted   Boolean   @default(false)
  /// Set when the user asks to keep a printed file instead of having it deleted
  /// straight away — the sweeper leaves the bytes alone until this passes. Null
  /// means no such request, which is the privacy-preserving default.
  keepUntil DateTime?
  createdAt DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order?

  @@index([userId])
}

model Order {
  id         String  @id @default(cuid())
  orderCode  String  @unique // e.g. PRT-8F3A2K
  userId     String
  documentId String  @unique
  printerId  String?

  // Copied from the printer at order time rather than joined through it. A
  // printer can later be reassigned, sold or deleted; a payout already made has
  // to keep pointing at whoever actually earned it.
  vendorId   String?
  locationId String?

  // print configuration
  colorMode       ColorMode @default(BW)
  sideMode        SideMode  @default(SINGLE)
  copies          Int       @default(1)
  pageRange       String    @default("all")
  pageColorModes  String?
  pagesToPrint    Int       @default(1)
  paperSize       String    @default("A4")
  costPaise       Int       @default(0)
  /// How many pages actually came out, when a print was interrupted (power cut,
  /// jam, printer stuck). Null means it was never partial — a normal order
  /// either printed in full or not at all.
  printedPages    Int?
  /// What this order settles to the vendor, in paise — the printed portion of a
  /// partial print, or the full cost of a clean one. Null on older/normal orders
  /// is read as the full costPaise; a partial print sets it to the earned share
  /// after the customer's pro-rata refund. This is what payouts are drawn from.
  settlementPaise Int?

  // payment
  paymentMethod      PaymentMethod?
  razorpayOrderId    String?
  razorpayPaymentId  String?
  /// The Route transfer (`trf_…`) that moved this order's share to the shop.
  /// Set only for a direct payment that was split at capture; null for Points
  /// orders (nothing was routed) and for orders taken before Route existed.
  /// Kept so a refund can reverse the exact transfer rather than guessing.
  razorpayTransferId String?

  status     OrderStatus @default(PENDING_PAYMENT)
  printToken String      @unique
  qrData     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  document      Document       @relation(fields: [documentId], references: [id])
  printer       Printer?       @relation(fields: [printerId], references: [id])
  vendor        Vendor?        @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  location      Location?      @relation(fields: [locationId], references: [id], onDelete: SetNull)
  printJob      PrintJob?
  complaints    Complaint[]
  refund        Refund?
  ratings       Rating[]
  refundRequest RefundRequest?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([vendorId])
}

/// A shop owner. One Vendor per vendor-console login.
///
/// Printers used to record their owner as loose text (ownerName, mobileNumber),
/// which meant nothing could actually be scoped to an owner — every printer route
/// had to be ADMIN-only because there was no way to ask "is this yours?".
model Vendor {
  id               String    @id @default(cuid())
  userId           String    @unique
  shopName         String
  contactName      String?
  mobileNumber     String?
  /// Set when an operator has checked the shop out. Null means unverified;
  /// `verificationNote` carries the reason when a check is rejected.
  verifiedAt       DateTime?
  verifiedById     String?
  verificationNote String?
  /// Set when a verification was explicitly turned down, so a rejected shop is
  /// distinguishable from one nobody has looked at yet.
  rejectedAt       DateTime?

  // ── KYC ──
  // What the shop submits so the platform can verify who it is paying. Numbers
  // only (no document images); the admin checks these on the verifications
  // queue, and approving there is the same act as verifying the shop.
  /// Legal name as printed on the shop's PAN — may differ from the display name.
  legalName      String?
  panNumber      String?
  aadhaarNumber  String?
  /// GST registration number. Optional — small shops aren't GST-registered.
  gstin          String?
  /// When the shop last submitted KYC for review. Null means never submitted;
  /// set with verifiedAt/rejectedAt both null means "under review".
  kycSubmittedAt DateTime?
  /// Set when an admin bans the shop. While set, its printers are hidden from
  /// the app and take no new orders. Orders already paid for are left alone —
  /// the customer still needs their print, or their refund.
  bannedAt       DateTime?
  banReason      String?
  bannedById     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  /// The shop's Razorpay Route linked account (`acc_…`).
  ///
  /// This is what makes a customer's payment reach *this* shop and no other.
  /// When it is set and `routeActive`, every direct (UPI/card) order at one of
  /// this shop's printers is split by Razorpay at capture time: the shop's share
  /// settles straight to this account, and only the platform commission stays
  /// with the platform. The money never rests in a platform balance to be paid
  /// out by hand — see lib/razorpayRoute.ts.
  ///
  /// Null means the shop hasn't onboarded yet. Its printers can still take Points
  /// orders, but a direct payment has nowhere to be routed, so those are blocked
  /// until onboarding completes rather than quietly landing in the platform
  /// account.
  razorpayAccountId String?
  /// True once Razorpay has activated the linked account and it can actually
  /// receive transfers. An account can exist (`razorpayAccountId` set) while
  /// still pending KYC, during which it must not be sent money.
  routeActive       Boolean @default(false)
  /// Last thing Razorpay told us about the account's onboarding — shown to the
  /// shop so a stuck KYC isn't a silent dead end.
  routeStatusNote   String?

  /// Average of the VISIBLE stars customers have given this shop, and how many
  /// there are. Denormalized because the app shows a star next to every printer
  /// on the pick-a-machine screen: computing it live would mean aggregating
  /// ratings for every vendor in range on each load of the busiest screen.
  ratingAvg   Float @default(0)
  ratingCount Int   @default(0)

  /// When the shop is open, as `{ mon: { open: "09:00", close: "20:00",
  /// closed: false }, ... }` keyed by the seven short day names.
  ///
  /// Json rather than a table of seven rows per vendor: nothing queries across
  /// it — it is read whole to render a week and written whole when the week is
  /// saved — and a `Location`-style relation would turn one read into a join
  /// for data that is never filtered on. The shape is validated in
  /// routes/vendors.ts before it is written, so a malformed week cannot land.
  ///
  /// Null means the shop has never set hours, which is displayed as "not set"
  /// rather than as "closed all week".
  operatingHours Json?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  locations      Location[]
  printers       Printer[]
  orders         Order[]
  payouts        Payout[]
  ratings        Rating[]
  refundRequests RefundRequest[]
  complaints     Complaint[]
}

/// A physical place a vendor operates from — one vendor can run several.
///
/// This is what makes the same printer model at different branches unambiguous:
/// each machine is its own Printer row pointing at the Location it stands in, so
/// a scanned QR resolves to one machine, at one place, owned by one vendor.
model Location {
  id        String   @id @default(cuid())
  vendorId  String
  name      String // e.g. "MG Road branch"
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor   Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  printers Printer[]
  orders   Order[]

  @@index([vendorId])
}

model Printer {
  id              String @id @default(cuid())
  uniquePrinterId String @unique // e.g. PRN-AB12CD

  // Ownership. Nullable so `prisma db push` doesn't reject the existing rows,
  // which predate vendors; scripts/backfill-vendors.ts fills them in and an
  // admin can reassign anything it couldn't work out.
  vendorId   String?
  locationId String?

  // Basic info
  name           String
  brand          String // Canon, HP, Epson, Brother, Samsung, Xerox, Other
  model          String
  serialNumber   String?
  ipAddress      String
  macAddress     String?
  wifiSsid       String? // Wi-Fi Direct SSID the printer broadcasts, e.g. "DIRECT-Pantum-BP5100"
  accessPassword String? // Wi-Fi Direct join password (shared with the app to connect + print)

  /// Set once an operator has confirmed this machine is real and reachable.
  verifiedAt       DateTime?
  verifiedById     String?
  rejectedAt       DateTime?
  verificationNote String?

  // Status
  status     PrinterStatus @default(OFFLINE)
  paperLevel Int           @default(100) // %
  tonerLevel Int           @default(100) // %
  lastSeenAt DateTime?

  // Location & owner
  locationName String // e.g. "Ground Floor - Shop 12"
  shopName     String
  ownerName    String
  mobileNumber String
  emailAddress String?
  address      String?

  // Capabilities
  supportedPaperSizes String[] @default(["A4"]) // ["A4","A3","Letter"]
  colorPrinting       Boolean  @default(false)
  duplexPrinting      Boolean  @default(false)

  // Pricing (in paise — 1 INR = 100 paise)
  costPerBWPagePaise    Int @default(200) // ₹2.00
  costPerColorPagePaise Int @default(1000) // ₹10.00

  // QR code
  qrCode String? // base64 PNG data URL
  qrData String? // the URL encoded in the QR

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor     Vendor?     @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  location   Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  orders     Order[]
  printJobs  PrintJob[]
  complaints Complaint[]

  @@index([status])
  @@index([shopName])
  @@index([vendorId])
  @@index([locationId])
}

model PrintJob {
  id         String         @id @default(cuid())
  orderId    String         @unique
  printerId  String
  status     PrintJobStatus @default(QUEUED)
  attempts   Int            @default(0)
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  printer Printer @relation(fields: [printerId], references: [id])

  @@index([status])
}

/// A problem report raised by a user from the mobile app — a dead printer, an
/// empty cartridge, pages that came out blank.
///
/// Deliberately separate from SupportTicket: that is a generic contact-us inbox
/// keyed by a typed-in email, whereas a complaint is always tied to the signed-in
/// account and usually to the specific order or printer that failed, which is
/// what makes it actionable (and refundable) without a back-and-forth.
model Complaint {
  id              String            @id @default(cuid())
  /// Human-quotable reference, e.g. CMP-8F3A2K.
  code            String            @unique
  userId          String
  /// The order that went wrong, when the user reported from an order.
  orderId         String?
  /// The machine involved. Kept even if the order is missing — a walk-up user
  /// can report a broken printer without having placed an order at all.
  printerId       String?
  /// The shop that owns the machine/order this is about. Copied at creation so
  /// the vendor queue can be scoped without joining through the printer, and so
  /// it survives the printer being reassigned. Null for platform-only issues
  /// (payment/points) with no shop behind them — those stay in the admin queue.
  vendorId        String?
  category        ComplaintCategory
  subject         String
  description     String
  status          ComplaintStatus   @default(OPEN)
  /// The customer asked for their money back as part of this issue. A refund is
  /// only ever issued by staff, after the shop forwards the issue on.
  refundRequested Boolean           @default(false)
  /// The shop passed this to the platform to decide. Refunds are admin-only, so
  /// forwarding is the vendor's move on a refund it can't grant itself.
  forwardedAt     DateTime?
  /// The shop's note to staff when forwarding.
  forwardNote     String?
  /// The refund this issue produced, once staff granted it. Null until then.
  refundId        String?           @unique
  /// Staff response, shown to the user on the complaint detail screen.
  resolution      String?
  resolvedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  order   Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  printer Printer?         @relation(fields: [printerId], references: [id], onDelete: SetNull)
  vendor  Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  photos  ComplaintPhoto[]

  @@index([userId])
  @@index([userId, createdAt])
  @@index([status])
  @@index([printerId])
  /// The shop's issue queue.
  @@index([vendorId, status, createdAt])
}

/// One side's rating of the other, for one completed order.
///
/// Every rating hangs off an order, and only the two parties to that order can
/// write one. That is the whole anti-abuse story: a shop cannot be review-
/// bombed by accounts that never printed there, and a student cannot be marked
/// a no-show by a shop they have never used. The `@@unique([orderId, direction])`
/// is what makes it one rating per side per order — enforced in the database
/// rather than by checking first, because two taps on a slow connection is the
/// ordinary case, not the exotic one.
///
/// Both subjects are stored on every row, whichever way it points: a shop's
/// rating of a student still records which vendor said it, so the console can
/// show a customer "rated by 3 of the 4 shops you've used" without walking back
/// through orders.
model Rating {
  id        String          @id @default(cuid())
  orderId   String
  direction RatingDirection

  /// 1–5. Range is enforced in ratings/types.ts — Prisma has no check constraint.
  stars   Int
  /// Free text, optional. A star with no words is still a rating.
  comment String?
  /// Quick-pick reasons. Validated against the direction before it is written.
  tags    RatingTag[]

  /// Who wrote it. For USER_TO_VENDOR this is the student; for VENDOR_TO_USER
  /// it is the vendor's own login, so a shop that changes hands still shows who
  /// actually left the rating.
  authorId String
  /// The student side of the order — the subject when VENDOR_TO_USER, and the
  /// author when USER_TO_VENDOR.
  userId   String
  /// The shop side of the order. Not nullable the way Order.vendorId is: a
  /// rating with no shop attached has nobody to be about.
  vendorId String

  status       RatingStatus @default(VISIBLE)
  /// Why staff hid it, shown in the moderation log. Null while VISIBLE.
  hiddenReason String?
  /// The admin who hid it. Not a relation, for the same reason bannedById isn't.
  hiddenById   String?
  hiddenAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author User   @relation("RatingAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  user   User   @relation("RatingSubjectUser", fields: [userId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  /// One rating per side per order.
  @@unique([orderId, direction])
  /// The shop's own ratings list, newest first.
  @@index([vendorId, direction, status, createdAt])
  /// A customer's received ratings, and "have I rated this order yet?".
  @@index([userId, direction, status, createdAt])
  @@index([authorId, createdAt])
  /// The admin moderation queue, which filters on status alone.
  @@index([status, createdAt])
}

/// A refund issued against an order.
///
/// Refunds are always paid as Prinsta Points, whatever the order was paid with:
/// the credit lands instantly, so a student whose print jammed can walk to the
/// next machine and try again rather than waiting a week for a card reversal.
///
/// One row per order — the unique constraint is what makes the whole thing safe
/// to retry. A duplicate refund is real money, and both the automatic hook and
/// the console button can fire for the same failed order, so the database
/// refuses the second one rather than trusting either caller to check first.
model Refund {
  id             String       @id @default(cuid())
  orderId        String       @unique
  userId         String
  /// What the order cost, in paise — kept so the ledger still reconciles if
  /// the points rate is ever changed.
  amountPaise    Int
  /// What was actually credited back, in points.
  pointsCredited Int
  reason         RefundReason
  origin         RefundOrigin @default(AUTOMATIC)
  /// Free text from staff on a manual refund.
  note           String?
  /// The admin who issued a manual refund. Null for automatic ones.
  issuedById     String?
  createdAt      DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

/// A customer asking for their money back.
///
/// This is the *ask*; `Refund` is the money actually moving. They are separate
/// tables because most requests never become a refund, and a rejected request
/// still has to be answerable months later — "I asked and they said no" is a
/// thing a student will come back about, and it needs a record.
///
/// One request per order (`orderId` is unique). A rejection is not an invitation
/// to keep asking the same shop until they give in; the way forward from a "no"
/// is ESCALATED, which is the same row moving into the platform's queue.
model RefundRequest {
  id       String  @id @default(cuid())
  /// Human-quotable reference, e.g. RFR-8F3A2K.
  code     String  @unique
  orderId  String  @unique
  userId   String
  /// The shop that has to answer it. Copied from the order rather than joined
  /// through it, for the same reason Order.vendorId is copied off the printer —
  /// a machine can be sold, and the request still belongs to whoever took the
  /// money.
  vendorId String?

  reason      RefundReason
  /// The customer's account of what went wrong, in their own words.
  description String
  status      RefundRequestStatus @default(PENDING)

  /// The vendor login that approved or rejected. Not a relation — it points at
  /// a User row and a back-reference here would have no use.
  decidedById  String?
  decidedAt    DateTime?
  /// The shop's reason, shown to the customer. Required on a rejection: a "no"
  /// with no explanation is what makes people escalate.
  decisionNote String?

  /// Set when the customer disputes a rejection.
  escalatedAt    DateTime?
  /// Why they think the shop got it wrong.
  escalationNote String?
  /// Staff's answer to the escalation.
  staffNote      String?
  resolvedById   String?
  resolvedAt     DateTime?

  /// The refund this became, once approved. Nullable because most requests
  /// never get here, and unique because one refund can't settle two requests.
  refundId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  /// The shop's pending queue — the hottest read on this table.
  @@index([vendorId, status, createdAt])
  /// The platform's escalation queue.
  @@index([status, createdAt])
}

/// Money paid out to a vendor for a period's takings.
///
/// The platform does not move money by itself: an operator makes the transfer
/// and records it here. That is why `status` can be FAILED and why `reference`
/// holds the bank's transaction id — this table is the record of what happened,
/// not the thing that makes it happen.
model Payout {
  id              String       @id @default(cuid())
  vendorId        String
  /// Gross takings this payout covers, before the platform's cut.
  grossPaise      Int
  /// The platform's cut, at the rate in force when the payout was drawn up.
  commissionPaise Int          @default(0)
  /// What the vendor actually receives — gross less commission.
  netPaise        Int
  /// The window this payout settles, so two payouts can't claim the same orders.
  periodStart     DateTime
  periodEnd       DateTime
  /// How many completed orders it covers, for reconciliation.
  orderCount      Int          @default(0)
  status          PayoutStatus @default(PENDING)
  /// Bank/UPI transaction reference, once the transfer has been made.
  reference       String?
  /// Why it failed, when it did.
  failureReason   String?
  note            String?
  createdById     String?
  processedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([status])
  @@index([vendorId, periodStart])
}

/// Evidence photo attached to a complaint — a shot of the jam, the faded page,
/// the error on the printer's panel. Stored in Neon alongside the row for the
/// same reason Document.fileData is: there is no external object storage.
model ComplaintPhoto {
  id          String   @id @default(cuid())
  complaintId String
  fileName    String
  mimeType    String
  data        Bytes
  sizeBytes   Int
  createdAt   DateTime @default(now())

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Single-row key-value store for platform settings (General, Pricing, Payments,
// Storage, Print rules, Notifications, Branding, Legal). One row, id = "app".
model AppSettings {
  id        String   @id @default("app")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}
