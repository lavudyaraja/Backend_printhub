# ── Prinsta admin backend config ─────────────────────────────────────────────
# Copy to .env and fill in. In production (NODE_ENV=production) the server
# REFUSES to boot if JWT_SECRET / ADMIN_SIGNUP_CODE / DATABASE_URL are missing
# or left at their default value.
#
# This backend is admin-only and cloud-only: no hardware, no IoT/MQTT, no object
# storage. All state lives in a Neon PostgreSQL database.

# Environment
NODE_ENV=development           # set "production" on the deployed server
PORT=4000

# Security — generate strong random values for production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string
ADMIN_SIGNUP_CODE=change_this_admin_code

# Google OAuth (same Client ID as NEXT_PUBLIC_GOOGLE_CLIENT_ID in admin/.env.local)
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Database — Neon PostgreSQL (the ONLY datastore).
# Neon dashboard → Connection Details → copy the pooled connection string.
DATABASE_URL="postgresql://user:pass@ep-xxxx.neon.tech/prinsta?sslmode=require"

# Public base URL of THIS backend.
BACKEND_URL=https://your-backend.onrender.com

# App URL encoded into printer QR codes (deep link the mobile app scans).
APP_URL=https://prinsta.app

# CORS — comma-separated allowed origins (admin console, etc). "*" allows all.
CORS_ORIGINS=*

# ── Razorpay (payments) — TEST mode first ────────────────────────────────────
# Dashboard → Settings → API Keys. Use rzp_test_… keys now; swap to rzp_live_…
# to go live (the server auto-detects the mode from the key prefix).
# If left blank, wallet top-ups and UPI checkout are disabled (wallet debits for
# orders still work).
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_key_secret

# Max upload size in bytes (default 50 MB)
MAX_UPLOAD_BYTES=52428800

# ── Email (Brevo free plan) — password-reset & login-alert emails ─────────────
# Leave BREVO_API_KEY blank in dev → reset codes are logged to the console and
# returned as `devCode` in the API response (no email sent).
#   1. Create a free account at https://app.brevo.com
#   2. Verify a sender or domain.
#   3. Settings → SMTP & API → API Keys → Generate a new key.
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxx
# MAIL_FROM=Prinsta <no-reply@yourdomain.com>

# ── Operator (platform admin) signup gate ────────────────────────────────────
# /auth/register-admin takes an accountType: "vendor" → OPERATOR (shop owner,
# open self-signup) or "operator" → ADMIN (platform staff, sees every vendor's
# data). Since the client supplies that field, the ADMIN path is gated on this
# shared code. LEAVE IT UNSET to disable operator self-signup entirely — the
# route refuses the operator path when this is blank rather than defaulting open.
# OPERATOR_SIGNUP_CODE=change-me-to-a-long-random-string
