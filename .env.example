# ── PrintHub backend config ──────────────────────────────────────────────────
# Copy to .env and fill in. In production (NODE_ENV=production) the server
# REFUSES to boot if JWT_SECRET / ADMIN_SIGNUP_CODE are missing or left default.

# Environment
NODE_ENV=development           # set "production" on the deployed server
PORT=4000

# Security — generate strong random values for production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string
ADMIN_SIGNUP_CODE=change_this_admin_code

# Database (PostgreSQL — Neon works great)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Public base URL of THIS backend (used to build file-download URLs for the IoT agent)
BACKEND_URL=https://your-backend.up.railway.app

# CORS — comma-separated allowed origins (admin dashboard, etc). "*" allows all.
CORS_ORIGINS=*

# MQTT broker — same one the IoT agents use.
#   Local:  mqtt://localhost:1883
#   HiveMQ Cloud (TLS + auth):  mqtts://USER:PASS@xxxxx.s1.eu.hivemq.cloud:8883
MQTT_URL=mqtt://localhost:1883

# Free printing for now — payment integration added later.
PAYMENT_ENABLED=false

# Pricing shown/charged (paise). B&W ₹2, Colour ₹10.
PRICE_BW_PAISE=200
PRICE_COLOR_PAISE=1000
