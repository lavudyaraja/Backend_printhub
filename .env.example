# ── PrintHub backend config ──────────────────────────────────────────────────
# Copy to .env and fill in. In production (NODE_ENV=production) the server
# REFUSES to boot if JWT_SECRET / ADMIN_SIGNUP_CODE are missing or left default.

# Environment
NODE_ENV=development           # set "production" on the deployed server
PORT=4000

# Security — generate strong random values for production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string
ADMIN_SIGNUP_CODE=change_this_admin_code

# Database (PostgreSQL — Neon works great)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Public base URL of THIS backend (used to build file-download URLs for the IoT agent)
BACKEND_URL=https://your-backend.up.railway.app

# CORS — comma-separated allowed origins (admin dashboard, etc). "*" allows all.
CORS_ORIGINS=*

# MQTT broker — same one the IoT agents use.
#   Local:  mqtt://localhost:1883
#   HiveMQ Cloud (TLS + auth):  mqtts://USER:PASS@xxxxx.s1.eu.hivemq.cloud:8883
MQTT_URL=mqtt://localhost:1883

# ── Backblaze B2 (S3-compatible) — the ONLY file store (temporary buffer) ────
# Files are held here only until printed, then deleted. Required for uploads.
# Setup:
#   1. Backblaze account → B2 Cloud Storage → Create a Bucket (Private).
#   2. App Keys → Add a New Application Key (scoped to that bucket).
#   3. The bucket's Endpoint (e.g. s3.us-east-005.backblazeb2.com) gives region.
# B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
# B2_REGION=us-east-005
# B2_BUCKET=selfprinter-files
# B2_KEY_ID=0005xxxxxxxxxxxxxxxxxxxxx
# B2_APP_KEY=K005xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Brevo free plan) — OTP, welcome & order-receipt emails ────
# OTP login + password-reset codes are emailed to the user's registered email.
# Leave BREVO_API_KEY blank in dev → codes are logged to the console and
# returned as `devCode` in the API response (no email sent). No SMS is used.
#
# Setup (free, no credit card):
#   1. Create a free account at https://app.brevo.com
#   2. Verify a sender: Senders, Domains & Dedicated IPs → Senders → Add a Sender.
#      Confirm the link Brevo emails you. (Or verify a whole domain — see below.)
#   3. Create an API key: Settings → SMTP & API → API Keys → Generate a new key.
#   4. Put the key in BREVO_API_KEY and use the *verified* address in MAIL_FROM.
#
# MAIL_FROM must use a Brevo-verified sender (or a verified domain), else Brevo
# rejects the send.
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxx
# MAIL_FROM=PrintHub <no-reply@yourdomain.com>

# Free printing for now — payment integration added later.
PAYMENT_ENABLED=false

# Pricing shown/charged (paise). B&W ₹2, Colour ₹10.
PRICE_BW_PAISE=200
PRICE_COLOR_PAISE=1000
